PORT=8080

# Incoming auth checked by this Railway proxy.
PROXY_API_KEY=replace-with-a-random-secret
# Optional alternative to x-api-key auth.
# PROXY_BEARER_TOKEN=replace-with-a-random-bearer-token

# Apify config.
APIFY_TOKEN=replace-with-your-apify-token
# Simplest option: paste the full Apify run-sync-get-dataset-items endpoint here.
# Example shape only, not a real value:
# APIFY_RUN_SYNC_URL=https://api.apify.com/v2/actor-tasks/<TASK_ID>/run-sync-get-dataset-items
APIFY_RUN_SYNC_URL=
# Optional if you prefer ids instead of a full URL.
# APIFY_TASK_ID=
# APIFY_ACTOR_ID=
APIFY_BASE_URL=https://api.apify.com/v2
APIFY_PROVIDER_NAME=apify_proxy
APIFY_TIMEOUT_MS=120000
APIFY_MAX_ITEMS=200

# Optional JSON merged into the payload sent to Apify.
# Useful when your chosen actor/task needs extra fields.
APIFY_STATIC_INPUT_JSON={}

# Optional human-friendly source URL returned to the backend.
# APIFY_PUBLIC_SOURCE_URL=https://console.apify.com
